{
  "project_name": "My Travel Vlog",
  "input_dir": "/absolute/path/to/video/materials",
  "output_dir": "outputs/my_travel_vlog",
  "final_editing_tool": "CapCut / Jianying",
  "context": {
    "theme": "Travel Vlog",
    "timeline": "Day 1 arrival, Day 2 sightseeing, Day 3 return",
    "locations": ["airport", "hotel", "beach", "restaurant"],
    "people": ["me", "friend A"],
    "keywords": ["boarding", "luggage", "sunset", "shopping"]
  },
  "frame_policy": {
    "default_frames": 1,
    "long_video_threshold_seconds": 30,
    "long_video_frames": 3
  },
  "transcription": {
    "enabled": false,
    "model": "small",
    "language": "zh",
    "keep_low_confidence": false
  }
}
